---
import Layout1 from "../layouts/Layout1.astro";
import Header from "../sections/header.astro";
import CreateCity from "../components/create_city.astro";
---

<Layout1 title="Dashboard">
  <Header />
  <CreateCity />

  <!-- MODAL DE ERROR DE CONEXIÓN -->
  <div id="error-overlay" class="modal-overlay" style="z-index: 10000;">
    <div class="error-modal flex-column">
      <i class="bi bi-wifi-off" style="font-size: 2.5rem; color: var(--clr-gray);"></i>
      <h4>Error de conexión</h4>
      <p style="text-align:center; font-size: 0.9rem;">No se pudo conectar con la base de datos.<br/>Verifica tu conexión e intenta de nuevo.</p>
      <button class="boton" onclick="location.reload()">
        <i class="bi bi-arrow-clockwise"></i> Recargar
      </button>
    </div>
  </div>

  <!-- OVERLAY DE CARGA INICIAL -->
  <div id="loading-initial" class="loading-overlay">
    <div class="flex-column" style="gap: 15px;">
      <div class="spinner"></div>
      <p style="color: var(--clr-text); font-size: 0.9rem;">
        Cargando campañas...
      </p>
    </div>
  </div>

  <!-- VISTA GENERAL DEL DASHBOARD -->
  <section id="dashboard" class="flex-row">
    <div id="pendiente" class="flex-column"></div>
    <div id="montada" class="flex-column"></div>
  </section>
</Layout1>

<style>
  #dashboard {
    display: flex;
    align-items: flex-start;
    gap: 0px;
    padding: 10px;
    max-width: 1100px;
    height: 100%;
    overflow: hidden;
  }

  #pendiente,
  #montada {
    width: 100%;
    height: 100%;
    text-align: center;
    padding: 20px;
    gap: 10px;
    justify-content: flex-start;
    overflow: hidden;
    flex-direction: column;
  }
</style>

<style is:inline>
  .header-section {
    width: 100%;
    justify-content: center;
    align-items: center;
    margin-bottom: 15px;
    flex-shrink: 0;
    gap: 10px;
    line-height: 1;
  }

  .header-section h2 {
    color: var(--clr-accent);
    font-size: 1.3rem;
    display: flex;
    align-items: center;
    gap: 8px;
    line-height: 1;
  }

  .header-section h2 .counter {
    color: var(--clr-text);
    font-size: 0.9rem;
    font-weight: 400;
    background-color: var(--clr-dark2);
    padding: 0;
    height: 32px;
    width: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    line-height: 1;
  }

  /* === ESTILOS PARA ELEMENTOS CLICKEABLES === */
  .clickable-img {
    cursor: pointer;
    transition: var(--transition);
    opacity: 1;
  }

  .clickable-text {
    cursor: pointer;
    transition: var(--transition);
  }

  .campaigns-container {
    width: 100%;
    max-width: 500px;
    gap: 10px;
    justify-content: flex-start;
    overflow-y: auto;
    overflow-x: hidden;
    height: 100%;
    flex: 1;
  }

  .campaign-card {
    background-color: var(--clr-dark2);
    padding: 16px 20px;
    width: 100%;
    gap: 7px;
    position: relative;
    border: solid 1px var(--clr-border);
    text-align: left;
    height: auto;
    flex-shrink: 0;
  }

  .campaign-header {
    width: 100%;
    gap: 5px;
    padding-bottom: 5px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .campaign-header h5 {
    color: var(--clr-accent);
    font-size: 1.1rem;
    margin: 0;
    cursor: pointer;
    transition: opacity 0.2s;
    user-select: none;
  }

  .campaign-header p {
    font-size: 0.85rem;
    color: var(--clr-text);
    display: flex;
    gap: 7px;
    margin: 0;
  }

  .campaign-header.clickable {
    cursor: pointer;
    transition: opacity 0.2s;
  }

  /* === BLOQUES DE DUPLAS (reutilizado también para audio) === */
  .bloque {
    padding: 12px;
    width: 100%;
    gap: 10px;
    background-color: var(--clr-dark);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .bloque h6 {
    width: 100%;
    color: var(--clr-accent);
    font-size: 0.8rem;
    text-align: left;
    font-weight: 600;
    margin: 0;
  }

  .bloque-content {
    width: 100%;
    display: flex;
    flex-direction: row;
    gap: 10px;
  }

  .bloque-item {
    flex: 1;
    background-color: var(--clr-dark);
    padding: 0px;
    gap: 4px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .bloque-item img {
    width: 192px;
    height: 192px;
    object-fit: cover;
    border: solid 1px var(--clr-border);
  }

  .bloque-item p {
    padding: 8px;
    background-color: var(--clr-dark);
    border: solid 1px var(--clr-border);
    color: var(--clr-text);
    font-size: 0.85rem;
    line-height: 1.2;
    height: 192px;
    width: 192px;
    overflow: hidden;
    overflow-wrap: break-word;
    margin: 0;
  }

  .bloque-item button {
    width: 100%;
    font-size: 0.8rem;
    padding: 8px 12px;
    gap: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .bloque-item button i {
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* === AUDIO DENTRO DEL BLOQUE === */
  .bloque-audio-content {
    width: 100%;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 8px;
  }

  .bloque-audio-content audio {
    flex: 1;
    height: 36px;
    min-width: 0;
  }

  .download-audio-btn {
    flex-shrink: 0;
    padding: 8px 12px;
    font-size: 0.8rem;
    gap: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    white-space: nowrap;
  }

  /* === MODAL DE DETALLE === */
  .campaign-detail-modal {
    background-color: var(--clr-dark);
    border: solid 1px var(--clr-border);
    width: 470px;
    max-width: 90%;
    max-height: 85vh;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 15px 20px;
    scroll-behavior: smooth;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 5px;
    justify-content: flex-start;
  }

  .campaign-detail-modal .campaign-header {
    width: 100%;
    gap: 5px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .campaign-detail-modal .campaign-header .header-top {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .campaign-detail-modal .campaign-header h5 {
    color: var(--clr-accent);
    font-size: 1.1rem;
    cursor: pointer;
    margin: 0;
  }

  .header-actions {
    display: flex;
    gap: 8px;
  }

  .header-actions i {
    background-color: var(--clr-dark2);
    border: solid 1px var(--clr-border);
    color: var(--clr-gray);
    padding: 8px;
    cursor: pointer;
    transition: var(--transition);
  }

  .campaign-detail-modal .campaign-header p {
    font-size: 0.85rem;
    color: var(--clr-text);
    display: flex;
    gap: 7px;
    margin: 0;
  }

  .campaign-detail-modal .campaign-header p:first-of-type {
    cursor: pointer;
  }

  .campaign-detail-modal .duplas-detail {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .campaign-status-switcher-modal {
    width: 100%;
    display: flex;
    gap: 7px;
    margin-top: 7px;
  }

  .status-btn {
    flex: 1;
    padding: 8px 12px;
    font-size: 0.75rem;
    border: solid 1px var(--clr-border);
    background-color: var(--clr-dark);
    color: var(--clr-gray);
    cursor: pointer;
    transition: var(--transition);
    font-weight: 600;
    text-transform: uppercase;
  }

  .status-btn.active {
    background-color: var(--clr-accent);
    color: var(--clr-dark);
    border-color: var(--clr-accent);
  }

  .empty-text {
    color: var(--clr-gray);
  }

  .error-modal {
    background-color: var(--clr-dark);
    border: solid 1px var(--clr-border);
    padding: 35px 30px;
    gap: 14px;
    max-width: 320px;
    width: 90%;
    text-align: center;
  }

  .error-modal h4 {
    color: var(--clr-white);
  }

  .empty-state {
    width: 100%;
    padding: 60px 20px;
    gap: 15px;
    color: var(--clr-gray);
  }

  .empty-state i {
    font-size: 3rem;
  }

  .empty-state h4 {
    color: var(--clr-text);
  }

  @media (hover: hover) {
    .campaign-header h5:hover {
      opacity: 0.7;
    }

    .campaign-header.clickable:hover {
      opacity: 0.8;
    }

    .header-actions i:hover {
      color: var(--clr-accent);
      background-color: var(--clr-border);
    }

    .status-btn:hover {
      background-color: var(--clr-border);
    }

    .clickable-img:hover {
      opacity: 0.4;
    }

    .clickable-text:hover {
      opacity: 0.4;
    }

    .status-btn.active:hover {
      background-color: var(--clr-accent);
    }
  }
</style>

<script>
  //@ts-nocheck
  import {
    getCampaigns,
    getCampaignById,
    deleteCampaign,
    updateCampaignStatus,
  } from "../lib/database.js";

  const $dashboard = document.getElementById("dashboard");
  const $loadingInitial = document.getElementById("loading-initial");
  const $errorOverlay = document.getElementById("error-overlay");

  let allCampaigns = [];
  let montadaSelectMode = false;
  let selectedMontadaIds = new Set();

  // Caché del detalle completo (duplas + audio) por id de campaña.
  // Se llena al pasar el mouse por la card (prefetch) → el click abre directo.
  const detailCache = new Map();

  function loadCampaignDetail(id) {
    if (!detailCache.has(id)) {
      const promise = getCampaignById(id).then((campaign) => {
        if (!campaign) detailCache.delete(id); // no cachear fallos
        return campaign;
      });
      detailCache.set(id, promise);
    }
    return detailCache.get(id);
  }

  document.addEventListener("DOMContentLoaded", async () => {
    $loadingInitial.style.display = "flex";
    try {
      const ok = await loadCampaigns();
      if (ok) renderCampaigns();
    } finally {
      $loadingInitial.style.display = "none";
    }
  });

  window.addEventListener("campaignAdded", async () => {
    detailCache.clear(); // el detalle pudo cambiar (crear/editar)
    const ok = await loadCampaigns();
    if (!ok) return;
    montadaSelectMode = false;
    selectedMontadaIds.clear();
    renderCampaigns();
  });

  async function loadCampaigns() {
    const result = await getCampaigns();
    if (result === null) {
      $errorOverlay.style.display = "flex";
      return false;
    }
    $errorOverlay.style.display = "none";
    allCampaigns = result;
    return true;
  }

  function renderCampaigns() {
    if (allCampaigns.length === 0) {
      $dashboard.innerHTML = `
        <div class="empty-state flex-column">
          <i class="bi bi-inbox"></i>
          <h4>No hay campañas aún</h4>
          <p>Haz clic en el botón + para crear tu primera campaña</p>
        </div>
      `;
      return;
    }

    const pendientes = allCampaigns.filter((c) => c.status === "pendiente");
    const montadas = allCampaigns.filter((c) => c.status === "montada");

    // Remove stale selections (campaign moved away from montadas)
    for (const id of selectedMontadaIds) {
      if (!montadas.find((c) => c.id === id)) selectedMontadaIds.delete(id);
    }

    const $pendienteDiv = document.getElementById("pendiente");
    const $montadaDiv = document.getElementById("montada");

    $pendienteDiv.innerHTML = `
      <div class="header-section flex-row">
        <h2>PENDIENTES <span class="counter">${pendientes.length}</span></h2>
      </div>
      <div class="campaigns-container flex-column">
        ${pendientes.length === 0 ? '<p class="empty-text">Sin campañas pendientes</p>' : ""}
        ${pendientes.map((c) => renderCampaignCard(c)).join("")}
      </div>
    `;

    const selectControls = montadaSelectMode
      ? `<button class="boton2 montada-cancel-select" style="font-size:0.75rem;padding:6px 12px;">Cancelar</button>
         ${selectedMontadaIds.size > 0 ? `<button class="boton montada-delete-selected" style="font-size:0.75rem;padding:6px 10px;gap:5px;"><i class="bi bi-trash"></i>Eliminar (${selectedMontadaIds.size})</button>` : ""}`
      : `<i class="bi bi-check2-square montada-select-toggle" title="Seleccionar varias" style="font-size:1.2rem;color:var(--clr-gray);cursor:pointer;padding:4px;transition:var(--transition);"></i>`;

    $montadaDiv.innerHTML = `
      <div class="header-section flex-row" style="gap:8px;">
        <h2>MONTADAS <span class="counter">${montadas.length}</span></h2>
        <div style="display:flex;gap:5px;align-items:center;">${selectControls}</div>
      </div>
      <div class="campaigns-container flex-column">
        ${montadas.length === 0 ? '<p class="empty-text">Sin campañas montadas</p>' : ""}
        ${montadas.map((c) => renderCampaignCard(c, montadaSelectMode)).join("")}
      </div>
    `;

    addEventListeners();
  }

  function renderCampaignCard(campaign, selectMode = false) {
    const isSelected = selectedMontadaIds.has(campaign.id);
    const selectedStyle = isSelected
      ? "border-color:var(--clr-accent);opacity:0.9;"
      : "";
    const checkIcon = selectMode
      ? `<i class="bi ${isSelected ? "bi-check-square-fill" : "bi-square"}" style="position:absolute;top:8px;right:8px;font-size:1rem;color:${isSelected ? "var(--clr-accent)" : "var(--clr-gray)"};pointer-events:none;"></i>`
      : "";

    return `
      <div class="campaign-card flex-column${selectMode ? " select-mode" : ""}" data-id="${campaign.id}" data-status="${campaign.status}" style="${selectedStyle}">
        ${checkIcon}
        <div class="campaign-header${selectMode ? "" : " clickable"}">
          <h5 class="${selectMode ? "" : "copy-city-name"}" data-city="${campaign.city_name}">${campaign.city_name}</h5>
          <p class="${selectMode ? "" : "copy-date"}" data-date="${formatDate(campaign.start_date)}"><i class="bi bi-calendar3"></i> ${formatDate(campaign.start_date)}</p>
          <p class="${selectMode ? "" : "copy-phone-number"}" data-phone="${campaign.phone_number}"><i class="bi bi-telephone-fill"></i> ${campaign.phone_number}</p>
        </div>
      </div>
    `;
  }

  function addEventListeners() {
    addCopyClickListener();
    addCardClickListener();
    addCardFieldCopyListeners();
    addSelectionListeners();
  }

  function addSelectionListeners() {
    document.querySelector(".montada-select-toggle")?.addEventListener("click", () => {
      montadaSelectMode = true;
      selectedMontadaIds.clear();
      renderCampaigns();
    });

    document.querySelector(".montada-cancel-select")?.addEventListener("click", () => {
      montadaSelectMode = false;
      selectedMontadaIds.clear();
      renderCampaigns();
    });

    document.querySelector(".montada-delete-selected")?.addEventListener("click", () => {
      const ids = [...selectedMontadaIds];
      const $confirmOverlay = document.getElementById("modal-confirm-overlay");
      const $confirmMessage = document.getElementById("confirm-message");
      const $confirmYes = document.querySelector(".confirm-yes");

      $confirmMessage.textContent = `¿Eliminar ${ids.length} campaña${ids.length !== 1 ? "s" : ""}?`;
      $confirmOverlay.style.display = "flex";

      const handleConfirm = async () => {
        $confirmOverlay.style.display = "none";
        $confirmYes.removeEventListener("click", handleConfirm);
        await deleteManyHandler(ids);
      };
      $confirmYes.addEventListener("click", handleConfirm);
    });

    if (montadaSelectMode) {
      document.querySelectorAll(".campaign-card.select-mode").forEach((card) => {
        card.addEventListener("click", () => {
          const id = parseInt(card.dataset.id);
          if (selectedMontadaIds.has(id)) {
            selectedMontadaIds.delete(id);
          } else {
            selectedMontadaIds.add(id);
          }
          renderCampaigns();
        });
      });
    }
  }

  function addCopyClickListener() {
    document.querySelectorAll("[data-copy]").forEach((element) => {
      element.addEventListener("click", (e) => {
        const text = e.currentTarget.dataset.copy;
        navigator.clipboard.writeText(text).then(() => {
          e.currentTarget.style.opacity = "0.7";
          setTimeout(() => { e.currentTarget.style.opacity = "1"; }, 500);
        });
      });
    });
  }

  function addCardFieldCopyListeners() {
    const fields = [
      { selector: ".copy-city-name", key: "city" },
      { selector: ".copy-date",      key: "date" },
      { selector: ".copy-phone-number", key: "phone" },
    ];
    fields.forEach(({ selector, key }) => {
      document.querySelectorAll(selector).forEach((el) => {
        el.addEventListener("click", (e) => {
          e.stopPropagation();
          navigator.clipboard.writeText(e.currentTarget.dataset[key]).then(() => {
            e.currentTarget.style.opacity = "0.5";
            setTimeout(() => { e.currentTarget.style.opacity = "1"; }, 300);
          });
        });
      });
    });
  }

  async function addCardClickListener() {
    document.querySelectorAll(".campaign-header.clickable").forEach((header) => {
      const card = header.closest(".campaign-card");
      const id = parseInt(card.dataset.id);

      // Prefetch: al pasar el mouse (o tocar) se va cargando el detalle en background.
      const prefetch = () => loadCampaignDetail(id);
      header.addEventListener("pointerenter", prefetch);
      header.addEventListener("pointerdown", prefetch);

      header.addEventListener("click", async (e) => {
        if (e.target.dataset.city || e.target.dataset.date || e.target.dataset.phone) return;

        // Si el prefetch (hover) ya cargó el detalle, el await resuelve al
        // instante y el spinner ni se llega a pintar → click directo.
        $loadingInitial.style.display = "flex";
        const campaign = await loadCampaignDetail(id);
        $loadingInitial.style.display = "none";

        if (campaign) {
          openCampaignModal(campaign);
        } else {
          $errorOverlay.style.display = "flex";
        }
      });
    });
  }

  function downloadFile(dataUrl, fileName) {
    const link = document.createElement("a");
    link.href = dataUrl;
    link.download = fileName;
    link.click();
  }

  async function deleteCampaignHandler(id) {
    // Optimistic: remove from memory immediately, sync DB in background
    const index = allCampaigns.findIndex((c) => c.id === id);
    if (index === -1) return;
    detailCache.delete(id);
    const [removed] = allCampaigns.splice(index, 1);
    renderCampaigns();

    const success = await deleteCampaign(id);
    if (!success) {
      allCampaigns.splice(index, 0, removed);
      renderCampaigns();
      alert("Error al eliminar la campaña");
    }
  }

  async function deleteManyHandler(ids) {
    // Optimistic: remove all from memory in reverse index order, then sync DB
    const removed = ids
      .map((id) => ({ id, index: allCampaigns.findIndex((c) => c.id === id) }))
      .filter(({ index }) => index !== -1)
      .sort((a, b) => b.index - a.index);

    for (const { index } of removed) {
      allCampaigns.splice(index, 1);
    }
    ids.forEach((id) => detailCache.delete(id));
    montadaSelectMode = false;
    selectedMontadaIds.clear();
    renderCampaigns();

    const results = await Promise.all(ids.map((id) => deleteCampaign(id)));
    const failed = ids.filter((_, i) => !results[i]);
    if (failed.length > 0) {
      await loadCampaigns();
      renderCampaigns();
      alert(`Error al eliminar ${failed.length} campaña${failed.length !== 1 ? "s" : ""}`);
    }
  }

  async function changeCampaignStatus(id, newStatus) {
    // Optimistic: update status in memory immediately, sync DB in background
    const campaign = allCampaigns.find((c) => c.id === id);
    if (!campaign) return;
    const previousStatus = campaign.status;
    campaign.status = newStatus;
    detailCache.delete(id); // el detalle cacheado tiene el estado viejo
    renderCampaigns();

    const success = await updateCampaignStatus(id, newStatus);
    if (!success) {
      campaign.status = previousStatus;
      renderCampaigns();
      alert("Error al cambiar el estado");
    }
  }

  function openCampaignModal(campaign) {
    const audioBlock = campaign.audio_url
      ? `
        <div class="bloque">
          <h6>AUDIO</h6>
          <div class="bloque-audio-content">
            <audio controls src="${campaign.audio_url}"></audio>
            <button class="boton download-audio-btn" data-audio="${campaign.audio_url}" data-city="${campaign.city_name}" data-date="${formatDate(campaign.start_date)}">
              <i class="bi bi-download"></i> Descargar
            </button>
          </div>
        </div>
      `
      : "";

    const modalHtml = `
      <div class="modal-overlay" id="campaign-detail-overlay" style="display: flex; z-index: 50;">
        <i class="bi bi-x-lg close-campaign-modal" style="position: fixed; top: 20px; right: 20px; cursor: pointer; font-size: 20px; background-color: var(--clr-dark); border: solid 1px var(--clr-border); padding: 7px; z-index: 100;"></i>
        <div class="campaign-detail-modal flex-column">
          <div class="campaign-header">
            <div class="header-top">
              <h5 data-copy="${campaign.city_name}">${campaign.city_name}</h5>
              <div class="header-actions">
                <i class="bi bi-pencil-square edit-campaign-modal" data-id="${campaign.id}"></i>
                <i class="bi bi-trash delete-campaign-modal" data-id="${campaign.id}"></i>
              </div>
            </div>
            <p data-copy="${formatDate(campaign.start_date)}"><i class="bi bi-calendar3"></i> ${formatDate(campaign.start_date)}</p>
            <p data-copy="${campaign.phone_number}"><i class="bi bi-telephone-fill"></i> ${campaign.phone_number}</p>
          </div>
          <hr />
          <div class="duplas-detail">
            ${campaign.duplas
              .sort((a, b) => a.dupla_order - b.dupla_order)
              .map(
                (dupla) => `
              <div class="bloque">
                <h6>DUPLA #${dupla.dupla_order}: ${dupla.name}</h6>
                <div class="bloque-content">
                  <div class="bloque-item">
                    <img src="${dupla.image_url}" alt="Imagen ${dupla.name}" class="clickable-img" data-img="${dupla.image_url}" data-name="${getImageFileName(campaign.city_name, dupla.dupla_order - 1)}" data-date="${formatDate(campaign.start_date)}" />
                  </div>
                  <div class="bloque-item">
                    <p class="clickable-text" data-text="${escapeHtml(dupla.text)}">${escapeHtml(dupla.text)}</p>
                  </div>
                </div>
              </div>
            `,
              )
              .join("")}
            ${audioBlock}
          </div>
          <hr />
          <div class="campaign-status-switcher-modal">
            <button class="status-btn ${campaign.status === "pendiente" ? "active" : ""}" data-status="pendiente" data-id="${campaign.id}">PENDIENTE</button>
            <button class="status-btn ${campaign.status === "montada" ? "active" : ""}" data-status="montada" data-id="${campaign.id}">MONTADA</button>
          </div>
        </div>
      </div>
    `;

    const modalDiv = document.createElement("div");
    modalDiv.innerHTML = modalHtml;
    document.body.appendChild(modalDiv.firstElementChild);

    const $detailOverlay = document.getElementById("campaign-detail-overlay");
    const $closeBtn = $detailOverlay.querySelector(".close-campaign-modal");
    const $editBtn = $detailOverlay.querySelector(".edit-campaign-modal");
    const $deleteBtn = $detailOverlay.querySelector(".delete-campaign-modal");

    const closeDetailModal = () => $detailOverlay.remove();

    $closeBtn.addEventListener("click", closeDetailModal);
    $detailOverlay.addEventListener("click", (e) => {
      if (e.target === $detailOverlay) closeDetailModal();
    });

    $editBtn.addEventListener("click", async () => {
      // `campaign` ya tiene duplas + audio (cargado al abrir el modal).
      window.dispatchEvent(
        new CustomEvent("editCampaign", { detail: campaign }),
      );
      closeDetailModal();
    });

    $deleteBtn.addEventListener("click", (e) => {
      const id = parseInt(e.currentTarget.dataset.id);
      const $confirmOverlay = document.getElementById("modal-confirm-overlay");
      const $confirmMessage = document.getElementById("confirm-message");
      const $confirmYes = document.querySelector(".confirm-yes");

      $confirmMessage.textContent = "¿Estás seguro de eliminar esta campaña?";
      $confirmOverlay.style.display = "flex";

      const handleConfirm = async () => {
        closeDetailModal();
        $confirmOverlay.style.display = "none";
        $confirmYes.removeEventListener("click", handleConfirm);
        await deleteCampaignHandler(id);
      };
      $confirmYes.addEventListener("click", handleConfirm);
    });

    $detailOverlay.querySelectorAll("[data-copy]").forEach((element) => {
      element.addEventListener("click", (e) => {
        const text = e.currentTarget.dataset.copy;
        navigator.clipboard.writeText(text).then(() => {
          e.currentTarget.style.opacity = "0.7";
          setTimeout(() => { e.currentTarget.style.opacity = "1"; }, 500);
        });
      });
    });

    $detailOverlay.querySelectorAll(".clickable-text").forEach((p) => {
      p.addEventListener("click", (e) => {
        const text = e.currentTarget.dataset.text;
        navigator.clipboard.writeText(text).then(() => {
          const originalText = e.currentTarget.textContent;
          e.currentTarget.textContent = "✓ Copiado!";
          setTimeout(() => { e.currentTarget.textContent = originalText; }, 1500);
        });
      });
    });

    $detailOverlay.querySelectorAll(".clickable-img").forEach((img) => {
      img.addEventListener("click", (e) => {
        const imgData = e.currentTarget.dataset.img;
        const fileName = e.currentTarget.dataset.name;
        const date = e.currentTarget.dataset.date;
        downloadFile(imgData, `${date}-${fileName}.png`);
      });
    });

    $detailOverlay.querySelector(".download-audio-btn")?.addEventListener("click", (e) => {
      const audioData = e.currentTarget.dataset.audio;
      const city = e.currentTarget.dataset.city;
      const date = e.currentTarget.dataset.date;
      const mimeMatch = audioData.match(/data:audio\/([a-zA-Z0-9]+);base64/);
      const rawExt = mimeMatch ? mimeMatch[1] : "ogg";
      const ext = rawExt === "mpeg" ? "mp3" : rawExt;
      downloadFile(audioData, `${date}-${city}-audio.${ext}`);
    });

    $detailOverlay.querySelectorAll(".campaign-status-switcher-modal .status-btn").forEach((btn) => {
      btn.addEventListener("click", async (e) => {
        const id = parseInt(e.currentTarget.dataset.id);
        const newStatus = e.currentTarget.dataset.status;
        closeDetailModal();
        await changeCampaignStatus(id, newStatus);
      });
    });
  }

  function formatDate(dateString) {
    const [year, month, day] = dateString.split("-");
    return `${day}/${month}/${year}`;
  }

  function getImageFileName(cityName, duplaIndex) {
    const suffix = duplaIndex === 0 ? "1" : "5";
    return `${cityName}${suffix}`;
  }

  function escapeHtml(text) {
    return text
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
  }
</script>
